#!/usr/bin/env bash
set -euo pipefail

# Copyright (C) 2025 Free Software Foundation, Inc.
# Copyright (C) 2026 IBM Corporation
#
# This generate_testdata.sh is free software; the author
# gives unlimited permission to copy and/or distribute it,
# with or without modifications, as long as this notice is preserved.
#
# This program is distributed in the hope that it will be useful,
# but WITHOUT ANY WARRANTY, to the extent permitted by law; without
# even the implied warranty of MERCHANTABILITY or FITNESS FOR A
# PARTICULAR PURPOSE.

#
# Example:
#
# generate_testdata.sh
#

CURRENT_VER=$(openssl version | awk '{print $2}')

# Triggers only if the version is less than 3.5
if awk -v ver="$CURRENT_VER" 'BEGIN {exit !(ver < 3.5)}'; then
    echo "❌ Error: OpenSSL $CURRENT_VER detected (required >= 3.5). Which does not support the MLDSA algorithms. Aborting."
fi

if ! command -v xxd >/dev/null 2>&1; then
    echo "❌ Error: 'xxd' is required but not installed. Aborting."
    exit 1
fi

TARGET_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TARGET_DIR="$TARGET_DIR/testdata"
cd $TARGET_DIR

################ TEST KEYS GENERATION #############################################

# 1. Generate keys for ML-DSA-44, ML-DSA-65 and ML-DSA-87
openssl genpkey -algorithm ML-DSA-44 -out "./leaf44.key"
openssl genpkey -algorithm ML-DSA-65 -out "./leaf65.key"
openssl genpkey -algorithm ML-DSA-87 -out "./leaf87.key"
openssl genpkey -algorithm ML-DSA-65 -out "./tamp.key"

# 2. Extracting the public key
openssl pkey -in "./leaf87.key" -pubout -outform DER | tail -c 2592 > "./pub87.key"
openssl pkey -in "./leaf65.key" -pubout -outform DER | tail -c 1952 > "./pub65.key"
openssl pkey -in "./leaf44.key" -pubout -outform DER | tail -c 1312 > "./pub44.key"
openssl pkey -in "./tamp.key" -pubout -outform DER | tail -c 1952 > "./tamp_pub.key"

# 3. Initialize and structure the C header file
cat << EOF > "./pubkeys.h"
/*
 *  GRUB  --  GRand Unified Bootloader
 *  Copyright (C) 2025 Free Software Foundation, Inc.
 *  Copyright (C) 2026 IBM Corporation
 *
 *  GRUB is free software: you can redistribute it and/or modify
 *  it under the terms of the GNU General Public License as published by
 *  the Free Software Foundation, either version 3 of the License, or
 *  (at your option) any later version.
 *
 *  GRUB is distributed in the hope that it will be useful,
 *  but WITHOUT ANY WARRANTY; without even the implied warranty of
 *  MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
 *  GNU General Public License for more details.
 *
 *  You should have received a copy of the GNU General Public License
 *  along with GRUB.  If not, see <http://www.gnu.org/licenses/>.
 *
 *  Note: This file is generated by generate_testdata.sh
 */

#ifndef PUBKEYS_H
#define PUBKEYS_H

EOF

# 4. Hex-dump binary signatures into C arrays
xxd -i "pub44.key" >> "./pubkeys.h"
xxd -i "pub65.key" >> "./pubkeys.h"
xxd -i "pub87.key" >> "./pubkeys.h"
xxd -i "tamp_pub.key" >> "./pubkeys.h"

# 5. Close the header guards
echo -e "\n#endif /* PUBKEYS_H */" >> "./pubkeys.h"

############################### END TEST KEYS GENERATION ##########################

################ TEST MESSAGES GENERATION #########################################

# 1. Create the source payload
printf "hello" > "./msg"
printf "hello test" > "./msg_tamp"
openssl rand -out "./large_msg" 65539

# 2. Initialize and structure the C header file
cat << EOF > "./messages.h"
/*
 *  GRUB  --  GRand Unified Bootloader
 *  Copyright (C) 2025 Free Software Foundation, Inc.
 *  Copyright (C) 2026 IBM Corporation
 *
 *  GRUB is free software: you can redistribute it and/or modify
 *  it under the terms of the GNU General Public License as published by
 *  the Free Software Foundation, either version 3 of the License, or
 *  (at your option) any later version.
 *
 *  GRUB is distributed in the hope that it will be useful,
 *  but WITHOUT ANY WARRANTY; without even the implied warranty of
 *  MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
 *  GNU General Public License for more details.
 *
 *  You should have received a copy of the GNU General Public License
 *  along with GRUB.  If not, see <http://www.gnu.org/licenses/>.
 *
 *  Note: This file is generated by generate_testdata.sh
 */

#ifndef MESSAGES_H
#define MESSAGES_H

EOF

# 3. Hex-dump the source payload into C arrays
echo "/* Message ('hello') */" >> "./messages.h"
xxd -i "msg" >> "./messages.h"
echo "/* Tampered message ('hello test') */" >> "./messages.h"
xxd -i "msg_tamp" >> "./messages.h"
echo "/* Greater than 65535 bytes of message */" >> "./messages.h"
xxd -i "large_msg" >> "./messages.h"

# 4. Close the header guards
echo -e "\n#endif /* MESSAGES_H */" >> "./messages.h"

################ END TEST MESSAGES GENERATION #####################################

################ TEST CONTEXTS GENERATION #########################################

# 1. Create the source payload
printf "tests" > "./ctx"
printf "tampered" > "./ctx_tamp"

# 2. Initialize and structure the C header file
cat << EOF > "./contexts.h"
/*
 *  GRUB  --  GRand Unified Bootloader
 *  Copyright (C) 2025 Free Software Foundation, Inc.
 *  Copyright (C) 2026 IBM Corporation
 *
 *  GRUB is free software: you can redistribute it and/or modify
 *  it under the terms of the GNU General Public License as published by
 *  the Free Software Foundation, either version 3 of the License, or
 *  (at your option) any later version.
 *
 *  GRUB is distributed in the hope that it will be useful,
 *  but WITHOUT ANY WARRANTY; without even the implied warranty of
 *  MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
 *  GNU General Public License for more details.
 *
 *  You should have received a copy of the GNU General Public License
 *  along with GRUB.  If not, see <http://www.gnu.org/licenses/>.
 *
 *  Note: This file is generated by generate_testdata.sh
 */

#ifndef CONTEXTS_H
#define CONTEXTS_H

EOF

# 3. Hex-dump the source payload into C arrays
echo "/* Context ('tests') */" >> "./contexts.h"
xxd -i "ctx" >> "./contexts.h"
echo "/* Tampered context ('tampered') */" >> "./contexts.h"
xxd -i "ctx_tamp" >> "./contexts.h"

# 4. Close the header guards
echo -e "\n#endif /* CONTEXTS_H */" >> "./contexts.h"

################ END TEST CONTEXTS GENERATION #####################################

################ TEST SIGNATURES GENERATION #######################################

# 1. Generate signatures without a context string
openssl pkeyutl -sign -inkey "./leaf44.key" -in "./msg" -out "./sig44_without_ctx"
openssl pkeyutl -sign -inkey "./leaf65.key" -in "./msg" -out "./sig65_without_ctx"
openssl pkeyutl -sign -inkey "./leaf87.key" -in "./msg" -out "./sig87_without_ctx"

openssl pkeyutl -sign -inkey "./leaf44.key" -in "./large_msg" -out "./sig44_lmsg_without_ctx"
openssl pkeyutl -sign -inkey "./leaf65.key" -in "./large_msg" -out "./sig65_lmsg_without_ctx"
openssl pkeyutl -sign -inkey "./leaf87.key" -in "./large_msg" -out "./sig87_lmsg_without_ctx"

# 2. Generate signatures with a context string ("tests")
openssl pkeyutl -sign -inkey "./leaf44.key" -in "./msg" -out "./sig44_with_ctx" -pkeyopt context-string:tests
openssl pkeyutl -sign -inkey "./leaf65.key" -in "./msg" -out "./sig65_with_ctx" -pkeyopt context-string:tests
openssl pkeyutl -sign -inkey "./leaf87.key" -in "./msg" -out "./sig87_with_ctx" -pkeyopt context-string:tests

openssl pkeyutl -sign -inkey "./leaf44.key" -in "./large_msg" -out "./sig44_lmsg_with_ctx" -pkeyopt context-string:tests
openssl pkeyutl -sign -inkey "./leaf65.key" -in "./large_msg" -out "./sig65_lmsg_with_ctx" -pkeyopt context-string:tests
openssl pkeyutl -sign -inkey "./leaf87.key" -in "./large_msg" -out "./sig87_lmsg_with_ctx" -pkeyopt context-string:tests

# 3. Initialize and structure the C header file
cat << EOF > "./signatures.h"
/*
 *  GRUB  --  GRand Unified Bootloader
 *  Copyright (C) 2025 Free Software Foundation, Inc.
 *  Copyright (C) 2026 IBM Corporation
 *
 *  GRUB is free software: you can redistribute it and/or modify
 *  it under the terms of the GNU General Public License as published by
 *  the Free Software Foundation, either version 3 of the License, or
 *  (at your option) any later version.
 *
 *  GRUB is distributed in the hope that it will be useful,
 *  but WITHOUT ANY WARRANTY; without even the implied warranty of
 *  MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the
 *  GNU General Public License for more details.
 *
 *  You should have received a copy of the GNU General Public License
 *  along with GRUB.  If not, see <http://www.gnu.org/licenses/>.
 *
 *  Note: This file is generated by generate_testdata.sh
 */

#ifndef SIGNATURES_H
#define SIGNATURES_H

EOF

# 4. Hex-dump binary signatures into C arrays
echo "/* Signatures with message ('hello') and context-string protection ('') */" >> "./signatures.h"
xxd -i "sig44_without_ctx" >> "./signatures.h"
xxd -i "sig65_without_ctx" >> "./signatures.h"
xxd -i "sig87_without_ctx" >> "./signatures.h"

echo -e "\n/* Signatures with message ('hello') and context-string protection ('tests') */" >> "./signatures.h"
xxd -i "sig44_with_ctx" >> "./signatures.h"
xxd -i "sig65_with_ctx" >> "./signatures.h"
xxd -i "sig87_with_ctx" >> "./signatures.h"

echo "/* Signatures with greater than 65535 bytes of message and context-string protection ('') */" >> "./signatures.h"
xxd -i "sig44_lmsg_without_ctx" >> "./signatures.h"
xxd -i "sig65_lmsg_without_ctx" >> "./signatures.h"
xxd -i "sig87_lmsg_without_ctx" >> "./signatures.h"

echo -e "\n/* Signatures with greater than 65535 bytes of message and context-string protection ('tests') */" >> "./signatures.h"
xxd -i "sig44_lmsg_with_ctx" >> "./signatures.h"
xxd -i "sig65_lmsg_with_ctx" >> "./signatures.h"
xxd -i "sig87_lmsg_with_ctx" >> "./signatures.h"

# 5. Close the header guards
echo -e "\n#endif /* SIGNATURES_H */" >> "./signatures.h"

############################### END TEST SIGNATURES GENERATION ############################

# Cleanup
rm -f msg leaf*.key pub*.key sig*_with_ctx sig*_without_ctx tamp_pub.key tamp.key large_msg msg_tamp ctx ctx_tamp

echo -e "\nMessages: $TARGET_DIR/messages.h\nContexts: $TARGET_DIR/contexts.h"
echo -e "Public Keys: $TARGET_DIR/pubkeys.h\nSignatures: $TARGET_DIR/signatures.h\n"
echo "✅ Success! test data has been generated."
